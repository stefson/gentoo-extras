From b24a8076022ff3f13a1edaa081e2696868c44860 Mon Sep 17 00:00:00 2001
From: Patrycja Rosa <mozcontrib@ptrcnull.me>
Date: Wed, 13 May 2026 00:55:01 +0000
Subject: [PATCH] Bug 1952657 - Only wrap header execinfo.h when it actually
 exists. r=glandium,firefox-build-system-reviewers

Differential Revision: https://phabricator.services.mozilla.com/D248421
---
 config/system-headers.mozbuild | 6 +++++-
 toolkit/moz.configure          | 2 ++
 2 files changed, 7 insertions(+), 1 deletion(-)

diff --git a/config/system-headers.mozbuild b/config/system-headers.mozbuild
index b2ed8f4c04fb7..0202ed39563a1 100644
--- a/config/system-headers.mozbuild
+++ b/config/system-headers.mozbuild
@@ -220,7 +220,6 @@ system_headers = [
     "exdisp.h",
     "ExDisp.h",
     "exe386.h",
-    "execinfo.h",
     "extras.h",
     "fcntl.h",
     "features.h",
@@ -1026,6 +1025,11 @@ system_headers = [
     "aom/aom_encoder.h",
 ]
 
+if CONFIG["HAVE_EXECINFO"]:
+    system_headers += [
+        "execinfo.h",
+    ]
+
 if CONFIG["MOZ_X11"]:
     system_headers += [
         "gdk/gdkx.h",
diff --git a/toolkit/moz.configure b/toolkit/moz.configure
index a7d998e3372bb..75e99bbd2490b 100644
--- a/toolkit/moz.configure
+++ b/toolkit/moz.configure
@@ -1622,6 +1622,8 @@ with only_when(compile_environment & depends(target.os)(lambda os: os != "WINNT"
 with only_when(compile_environment & depends(target.os)(lambda os: os != "WINNT")):
     set_define("HAVE_SYSIOCCOM_H", check_header("sys/ioccom.h"))
 
+    set_config("HAVE_EXECINFO", check_header("execinfo.h"))
+
 # Elfhack
 # ==============================================================
 with only_when("--enable-compile-environment"):
