From 30a354b6625fc79b01f9d1f36f60cea2a669248e Mon Sep 17 00:00:00 2001
From: Lars Eggert <lars@eggert.org>
Date: Wed, 17 Jun 2026 08:25:50 +0000
Subject: [PATCH] Bug 2047651 - Link freebl explicitly for system NSS builds
 r=valentin,necko-reviewers

nss-rs's blapi feature makes gkrust reference FREEBL_GetVector, but the system
nss.pc does not list the freebl library. Link it explicitly.

Differential Revision: https://phabricator.services.mozilla.com/D306969
---
 security/moz.build | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/security/moz.build b/security/moz.build
index 5f3bce2b37b05..90bae217e5c81 100644
--- a/security/moz.build
+++ b/security/moz.build
@@ -22,6 +22,10 @@ with Files("nss.symbols"):
 if CONFIG["MOZ_SYSTEM_NSS"]:
     Library("nss")
     OS_LIBS += CONFIG["NSS_LIBS"]
+    if CONFIG["OS_TARGET"] == "Linux":
+        OS_LIBS += ["-lfreeblpriv3"]
+    else:
+        OS_LIBS += ["-lfreebl3"]
 
 include("/build/gyp_base.mozbuild")
 if CONFIG["MOZ_FOLD_LIBS"]:

