From 6fbb828951799a77d29565ff768df3c3717ff446 Mon Sep 17 00:00:00 2001
From: Lars Eggert <lars@eggert.org>
Date: Mon, 15 Jun 2026 11:36:11 +0000
Subject: [PATCH] Bug 2047256 - Fix out-of-tree NSS build
 r=valentin,necko-reviewers

Differential Revision: https://phabricator.services.mozilla.com/D306694
---
 toolkit/library/moz.build | 10 ++++++----
 1 file changed, 6 insertions(+), 4 deletions(-)

diff --git a/toolkit/library/moz.build b/toolkit/library/moz.build
index 29b327c17181c..a713a301040f8 100644
--- a/toolkit/library/moz.build
+++ b/toolkit/library/moz.build
@@ -162,10 +162,12 @@ USE_LIBS += [
 # must be an explicit dependency. This cannot go into security/moz.build,
 # because in fold_libs mode, freebl3 itself links against nspr4, which is
 # folded into nss3, creating a nss3 → freebl3 → nss3 circular dependency.
-if CONFIG["OS_TARGET"] == "Linux":
-    USE_LIBS += ["freeblpriv3"]
-else:
-    USE_LIBS += ["freebl3"]
+# For system NSS, freebl is linked by the nss-rs build.rs via pkg-config instead.
+if not CONFIG["MOZ_SYSTEM_NSS"]:
+    if CONFIG["OS_TARGET"] == "Linux":
+        USE_LIBS += ["freeblpriv3"]
+    else:
+        USE_LIBS += ["freebl3"]
 
 if not CONFIG["USE_LIBZ_RS"]:
     USE_LIBS += [

